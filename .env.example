# ─── Base de datos (Supabase PostgreSQL) ──────────────────────────────────────
# Cadena de conexión completa incluyendo usuario, contraseña, host, puerto y DB.
# Ejemplo: postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# ─── Autenticación ────────────────────────────────────────────────────────────
# String aleatorio largo (mínimo 32 caracteres) usado para firmar los JWT.
# Genera uno con: openssl rand -hex 32
JWT_SECRET=

# ─── DigitalOcean Spaces ──────────────────────────────────────────────────────
# Región del Space (ej: nyc3, sfo3, ams3)
DO_SPACES_REGION=

# URL base del endpoint de la región (sin el nombre del bucket)
# Ejemplo: https://nyc3.digitaloceanspaces.com
DO_SPACES_ENDPOINT=

# Nombre del bucket (Space)
DO_SPACES_BUCKET=

# Credenciales de acceso generadas en DO → Spaces → Manage Keys
DO_SPACES_ACCESS_KEY=
DO_SPACES_SECRET_KEY=

# ─── CRM (integración de reclamos) ────────────────────────────────────────────
# URL base de la API del CRM (sin trailing slash)
CRM_API_URL=

# Código SAP del proyecto en el CRM
CRM_PROYECTO_SAP=

# Código de medio de reclamo configurado en el CRM
CRM_MEDIO_RECLAMO=
